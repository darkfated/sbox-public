@namespace Sandbox.UI.Dev
@using Sandbox.UI.Dev.Stats
@inherits Panel

<root class="stats-container">
	<PerformanceStats />
	<GarbageStats />
	<RenderStats />
	<SceneStats />

	@if ( Networking.IsActive )
	{
		<NetworkStats />

		@if ( !Networking.IsHost )
		{
			<HostStats />
		}
	}
</root>

@code
{
	protected override int BuildHash() => HashCode.Combine( Networking.IsActive );
}
