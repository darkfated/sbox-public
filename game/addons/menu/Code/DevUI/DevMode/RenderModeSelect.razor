@namespace Sandbox.UI.Dev
@inherits Panel

<root>
    <div class="trigger" onclick="@ToggleMenu">
        <i>@CurrentIcon</i>
        <span>@CurrentTitle</span>
    </div>

    @if ( _menuOpen )
    {
        <div class="menu-overlay">
            @foreach ( var (mode, info) in DebugModes )
            {
                var captured = mode;
                var modeClass = mode == _selectedMode ? "mode-option active" : "mode-option";
                <div class="@modeClass" onclick="@(() => SelectMode( captured ))">
                    <i>@(info.Icon ?? "image")</i>
                    <span>@(info.Name ?? captured.ToString())</span>
                </div>
            }
        </div>
    }
</root>


@code
{
    static readonly (SceneCameraDebugMode value, DisplayInfo info)[] DebugModes
        = DisplayInfo.ForEnumValues<SceneCameraDebugMode>();

    SceneCameraDebugMode _selectedMode;
    bool _menuOpen;

    string CurrentTitle => GetDisplayInfo().Name ?? _selectedMode.ToString();
    string CurrentIcon => GetDisplayInfo().Icon ?? "image";

    DisplayInfo GetDisplayInfo()
    {
        foreach ( var (value, info) in DebugModes )
            if ( value == _selectedMode ) return info;

        return default;
    }

    void SetMode( SceneCameraDebugMode mode )
    {
        _selectedMode = mode;
        ConsoleSystem.Run( "mat_toolsvis", mode.ToString() );

        StateHasChanged();
    }

    void ToggleMenu()
    {
        _menuOpen = !_menuOpen;
        DeveloperMode.Current?.SetRenderModePickerOpen( _menuOpen );
        StateHasChanged();
    }

    void SelectMode( SceneCameraDebugMode mode )
    {
        SetMode( mode );
        _menuOpen = false;
        DeveloperMode.Current?.SetRenderModePickerOpen( false );
        StateHasChanged();
    }

    bool TryGetModeFromConvar( out SceneCameraDebugMode mode )
    {
        mode = default;

        var raw = ConsoleSystem.GetValue( "mat_toolsvis" );
        if ( string.IsNullOrWhiteSpace( raw ) )
            return false;

        raw = raw.Trim().Trim( '"' );

        if ( Enum.TryParse<SceneCameraDebugMode>( raw, true, out var parsedMode ) && Enum.IsDefined( typeof( SceneCameraDebugMode ), parsedMode ) )
        {
            mode = parsedMode;
            return true;
        }

        return false;
    }

    public override void Tick()
    {
        base.Tick();

        var actual = _selectedMode;
        if ( TryGetModeFromConvar( out var convarMode ) )
            actual = convarMode;

        if ( _selectedMode != actual )
        {
            _selectedMode = actual;
            StateHasChanged();
        }

        SetClass( "active", _selectedMode != SceneCameraDebugMode.Normal );
        SetClass( "open", _menuOpen );
    }
}
