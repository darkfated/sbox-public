@namespace Sandbox.UI.Dev
@inherits Panel

<root>
    <div class="picker">
        <div class="trigger" onmousedown="@ToggleMenu">
            <i class="trigger-icon">@CurrentIcon</i>
            <div class="trigger-copy">
                <span class="eyebrow">Render Mode</span>
                <span class="title">@CurrentTitle</span>
            </div>
            <i class="trigger-arrow">expand_more</i>
        </div>

        <div class=@($"menu-overlay {(_menuOpen ? "open" : "hidden")}")>
            @foreach ( var (mode, info) in DebugModes )
            {
                var captured = mode;
                var modeClass = mode == _selectedMode ? "mode-option active" : "mode-option";
                <div class="@modeClass" onmousedown="@(() => SelectMode( captured ))">
                    <i class="mode-icon">@(info.Icon ?? "image")</i>
                    <div class="mode-copy">
                        <span class="title">@(info.Name ?? captured.ToString())</span>
                        @if ( !string.IsNullOrWhiteSpace( info.Description ) )
                        {
                            <span class="meta">@info.Description</span>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</root>


@code
{
    static readonly (SceneCameraDebugMode value, DisplayInfo info)[] DebugModes
        = DisplayInfo.ForEnumValues<SceneCameraDebugMode>();

    [Parameter]
    public Action<bool> SetRenderModePickerOpen { get; set; }

    SceneCameraDebugMode _selectedMode;
    bool _menuOpen;

    DisplayInfo CurrentInfo => GetDisplayInfo();
    string CurrentTitle => CurrentInfo.Name ?? _selectedMode.ToString();
    string CurrentIcon => CurrentInfo.Icon ?? "image";

    DisplayInfo GetDisplayInfo()
    {
        foreach ( var (value, info) in DebugModes )
            if ( value == _selectedMode )
                return info;

        return default;
    }

    void SetMode( SceneCameraDebugMode mode )
    {
        _selectedMode = mode;
        ConsoleSystem.Run( "mat_toolsvis", mode.ToString() );
        StateHasChanged();
    }

    void ToggleMenu()
    {
        Sound.Play( "ui.button.press" );
        if ( _menuOpen )
        {
            _menuOpen = false;
            SetRenderModePickerOpen?.Invoke( false );
            StateHasChanged();
            return;
        }

        SyncFromConvar();
        _menuOpen = true;
        SetRenderModePickerOpen?.Invoke( _menuOpen );
        StateHasChanged();
    }

    void SelectMode( SceneCameraDebugMode mode )
    {
        Sound.Play( "ui.button.press" );
        SetMode( mode );
        _menuOpen = false;
        SetRenderModePickerOpen?.Invoke( false );
        StateHasChanged();
    }

    void SyncFromConvar()
    {
        if ( TryGetModeFromConvar( out var convarMode ) )
            _selectedMode = convarMode;
    }

    bool TryGetModeFromConvar( out SceneCameraDebugMode mode )
    {
        mode = default;

        var raw = ConsoleSystem.GetValue( "mat_toolsvis" );
        if ( string.IsNullOrWhiteSpace( raw ) )
            return false;

        raw = raw.Trim().Trim( '"' );

        if ( Enum.TryParse<SceneCameraDebugMode>( raw, true, out var parsedMode ) && Enum.IsDefined( typeof( SceneCameraDebugMode ), parsedMode ) )
        {
            mode = parsedMode;
            return true;
        }

        return false;
    }

    public override void Tick()
    {
        base.Tick();

        if ( _menuOpen && !DeveloperMode.Open )
        {
            _menuOpen = false;
            SetRenderModePickerOpen?.Invoke( false );
            StateHasChanged();
        }

        if ( !_menuOpen )
        {
            var actual = _selectedMode;
            if ( TryGetModeFromConvar( out var convarMode ) )
                actual = convarMode;

            if ( _selectedMode != actual )
            {
                _selectedMode = actual;
                StateHasChanged();
            }
        }

        SetClass( "open", _menuOpen );
    }
}
